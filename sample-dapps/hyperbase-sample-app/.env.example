QUICKNODE_API_KEY=your_quicknode_api_key_here

# Local development (default — uses local SQLite file, no Turso account needed)
# TURSO_DATABASE_URL=file:./data/hyperbase.db

# Production (Turso cloud — create a free DB at https://turso.tech)
# TURSO_DATABASE_URL=libsql://your-db-name.turso.io
# TURSO_AUTH_TOKEN=your_turso_auth_token_here
