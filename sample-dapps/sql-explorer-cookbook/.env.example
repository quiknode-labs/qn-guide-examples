# Required: Quicknode API key with "SQL" application enabled
# Get yours at https://dashboard.quicknode.com/api-keys
QUICKNODE_API_KEY=your_quicknode_api_key

# SQL Explorer REST API endpoint
QUICKNODE_SQL_ENDPOINT=https://api.quicknode.com/sql/rest/v1/query

# Cluster ID for Hyperliquid data
QUICKNODE_CLUSTER_ID=hyperliquid-core-mainnet
