    "@grpc/proto-loader": "^0.7.13",
    "chalk": "^5.3.0",
    "cli-table3": "^0.6.5",
    "dotenv": "^16.4.7"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
